rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /orders/{orderId} {
      allow read, write: if true;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if true; 
      allow delete: if request.auth != null && isAdmin();
    }

    match /shops/{shopId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if request.auth != null && isAdmin();
    }
    
    match /merchants/{merchantId} {
      allow read: if true;
      allow create: if true;
      allow update: if (request.auth != null && isAdmin()) || 
        (request.auth != null && (resource.data.authUid == request.auth.uid || resource.data.email == request.auth.token.email)) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAcceptingOrders', 'openTime', 'closeTime']);
      allow delete: if request.auth != null && isAdmin();
    }

    match /delivery_boys/{riderId} {
      allow read: if true;
      allow create: if true;
      allow update: if (request.auth != null && isAdmin()) || 
        (request.auth != null && (resource.data.authUid == request.auth.uid || resource.data.email == request.auth.token.email)) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isOnline', 'lat', 'lng', 'status', 'totalDeliveries', 'pendingPayout', 'updatedAt']);
      allow delete: if request.auth != null && isAdmin();
    }

    match /customers/{customerId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == customerId;
      allow delete: if request.auth != null && isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    match /{document=**} {
      allow read: if true; 
      allow write: if request.auth != null && isAdmin(); 
    }
  }
}
