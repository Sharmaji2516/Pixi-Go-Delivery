rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    // Helper: Check if user is an Admin
    function isAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email != null && request.auth.token.email in ['pixigodelivery@gmail.com', 'lavsharma.it25@gmail.com', 'shaktisinghnarela150@gmail.com'])
      );
    }
    // Helper: Check if user is a registered Merchant
    function isMerchant() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/merchants/$(request.auth.uid)) ||
        (request.auth.token.email != null && request.auth.token.email in ['lavsharma.it25@gmail.com', 'pixigodelivery@gmail.com'])
      );
    }
    // Helper: Check if user is a registered Delivery Rider
    function isRider() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/delivery_boys/$(request.auth.uid))
      );
    }
    // Helper: Check if the logged-in merchant owns the store name
    // Enforces exists() check before get() to prevent runtime crashes
    function isStoreOwner(storeName) {
      return isMerchant() && 
        exists(/databases/$(database)/documents/merchants/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/merchants/$(request.auth.uid)).data.storeName == storeName ||
          get(/databases/$(database)/documents/merchants/$(request.auth.uid)).data.name == storeName
        );
    }

    // 1. Admins Collection
    match /admins/{adminId} {
      allow read: if isAuthenticated() && (isOwner(adminId) || isAdmin());
      allow write: if isAdmin() || (isOwner(adminId) && request.auth.token.email in ['pixigodelivery@gmail.com', 'lavsharma.it25@gmail.com', 'shaktisinghnarela150@gmail.com']);
    }
    // 2. Customers Collection
    match /customers/{customerId} {
      allow read: if isAuthenticated() && (isOwner(customerId) || isAdmin());
      allow create, update: if isAuthenticated() && (isOwner(customerId) || isAdmin());
      allow delete: if isAdmin();
    }
    // 3. Merchants Collection
    match /merchants/{merchantId} {
      allow read: if true; // Publicly readable for customer browsing
      allow create: if true; // Allow self-onboarding/registration request
      allow update: if isAdmin() || (isAuthenticated() && (
        resource.data.authUid == request.auth.uid || 
        resource.data.email == request.auth.token.email
      ));
      allow delete: if isAdmin();
    }
    // 4. Delivery Boys (Riders) Collection
    match /delivery_boys/{riderId} {
      allow read, create: if true; // Publicly readable for tracking/login, allow self-registration
      allow update: if isAdmin() || (isAuthenticated() && (
        resource.data.authUid == request.auth.uid || 
        resource.data.email == request.auth.token.email
      ));
      allow delete: if isAdmin();
    }
    // 5. Products Collection
    match /products/{productId} {
      allow read: if true; // Public catalog
      allow create: if isAdmin() || isMerchant();
      allow update, delete: if isAdmin() || isStoreOwner(resource.data.store);
    }
    // 6. Orders Collection
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.merchantId == request.auth.uid ||
        resource.data.deliveryPartnerId == request.auth.uid ||
        resource.data.customerPhone == request.auth.token.phone_number ||
        isAdmin()
      );
      
      allow create: if isAuthenticated() && (request.resource.data.customerId == request.auth.uid || isAdmin());
      allow update: if isAdmin() || (isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.merchantId == request.auth.uid ||
        resource.data.deliveryPartnerId == request.auth.uid ||
        // Allow an authorized rider to accept an unassigned order
        (resource.data.deliveryPartnerId == null && request.resource.data.deliveryPartnerId == request.auth.uid && isRider())
      ));
      
      allow delete: if isAdmin();
    }
    // 7. Payouts Collection
    match /payouts/{payoutId} {
      allow read: if isAdmin() || (isAuthenticated() && (
        resource.data.userId == request.auth.uid
      ));
      allow write: if isAdmin();
    }
    // 8. Coupons Collection
    match /coupons/{couponId} {
      allow read: if true; // Publicly readable for discount application
      allow write: if isAdmin();
    }
    // 9. Configs Collection (Announcements, Deals, etc.)
    match /configs/{configId} {
      allow read: if true; // Publicly readable for announcements & deals
      allow write: if isAdmin();
    }
  }
}
