rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isAdmin() || 
        (
          resource.data.merchantId != null &&
          exists(/databases/$(database)/documents/merchants/$(resource.data.merchantId)) &&
          (
            get(/databases/$(database)/documents/merchants/$(resource.data.merchantId)).data.authUid == request.auth.uid ||
            get(/databases/$(database)/documents/merchants/$(resource.data.merchantId)).data.email == request.auth.token.email
          )
        ) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'deliveryPartnerId', 'deliveryPartnerName'])
      );
      allow delete: if request.auth != null && isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if request.auth != null; 
      allow delete: if request.auth != null && isAdmin();
    }

    match /shops/{shopId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null && isAdmin();
    }
    
    match /merchants/{merchantId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isAdmin() || 
        resource.data.authUid == request.auth.uid ||
        resource.data.email == request.auth.token.email
      );
      allow delete: if request.auth != null && isAdmin();
    }

    match /delivery_boys/{riderId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isAdmin() || 
        resource.data.authUid == request.auth.uid ||
        resource.data.email == request.auth.token.email
      );
      allow delete: if request.auth != null && isAdmin();
    }

    match /customers/{customerId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == customerId;
      allow delete: if request.auth != null && isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    match /{document=**} {
      allow read: if true; 
      allow write: if request.auth != null && isAdmin(); 
    }
  }
}
