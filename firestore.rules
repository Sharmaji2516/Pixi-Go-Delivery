rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Security rules for the 'orders' collection
    match /orders/{orderId} {
      // Allow anyone (even unauthenticated guest users) to place an order
      allow create: if true;
      
      // Allow reading, updating, or deleting orders if the user is authenticated
      allow read, update, delete: if request.auth != null;
    }
    
    // Default rules for other collections during development
    match /{document=**} {
      // Allow authenticated read/write for all other paths
      allow read, write: if request.auth != null;
    }
  }
}
